# Input: any valid input
# Output: 1 if the input are two concatenated identical lists of numbers (e.g. 1 2 3 1 2 3), otherwise 0

c = ρ input;

if c mod 2==1:
	output = 0;
	exit;
endif;

partB = input…;
partA = [];
x = (c ∶ 2);
while x > 0:
	partA[] = partB[0];
	partB = partB[1:];
	x−−;
endwhile;
x = (c ∶ 2);
output = 1;
while x > 0:
	if partA[0]≠partB[0]:
		output = 0;
		break;
	endif;
	partA = partA[1:];
	partB = partB[1:];
	x−−;
endwhile;
