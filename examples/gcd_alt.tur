# Input: two numbers
# Output: their greatest common divisor; 0 if both numbers are 0

# The machine will be huge because of two-layered inclusion of tur-compiled machines.

include primeDecomposition;

[a, b] = input...;

primesA = primeDecomposition(a)...;
primesB = primeDecomposition(b)...;

output = 1;

while (ρ primesA) > 0 ∧ (ρ primesB) > 0:
	if primesA[0]==primesB[0]:
		output = output ⋅ primesA[0];
	endif;
	primesA = primesA[1:];
	primesB = primesB[1:];
endwhile;
