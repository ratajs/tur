# Input: one number n
# Output: prime decomposition of n

# The machine will be quite big because of inclusion of a tur-compiled machine.

inc = { A11LA A01N_ };
include primes;

number = input;
primeNumbers = primes(inc(number))...;

output = [];
while number!=1:
	if number % primeNumbers[0]==0:
		output[] = primeNumbers[0];
		number = number / primeNumbers[0];
	else:
		primeNumbers = primeNumbers[1:];
	endif;
endwhile;
